# Engine selection: auto | ollama | mock
JARVIS_ENGINE=auto

# Ollama endpoint
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Privacy guard:
# - unset/0 => Jarvis refuses non-local Ollama endpoints
# - 1 => allow remote Ollama endpoints explicitly
JARVIS_ALLOW_REMOTE_OLLAMA=0

# Keep Ollama model warm between requests to reduce second-turn latency
JARVIS_OLLAMA_KEEP_ALIVE=30m

# Request timeout guard for Ollama calls (milliseconds)
JARVIS_OLLAMA_TIMEOUT_MS=180000

# API hardening (optional)
# Set a key to require auth on /v1/* endpoints
JARVIS_API_KEY=

# CORS:
# - unset => local browser origins only (recommended)
# - false => disable CORS headers
# - true or * => allow all origins (not recommended)
# - comma-separated origins => allow list
JARVIS_CORS_ORIGIN=

# Set to 1 to suppress runtime security warning logs
JARVIS_SUPPRESS_SECURITY_WARNINGS=0

# Agent permissions:
# Set any of these to 0 to disable that tool class in agent mode.
JARVIS_ENABLE_SHELL_TOOLS=1
JARVIS_ENABLE_FILE_TOOLS=1
JARVIS_ENABLE_SYSTEM_TOOLS=1
JARVIS_ENABLE_OBSIDIAN_TOOLS=1
JARVIS_ENABLE_RAG_TOOLS=1
JARVIS_ENABLE_CALENDAR_TOOLS=1

# Linux desktop rendering override (optional): x11 | wayland
JARVIS_OZONE_PLATFORM=

# Google Calendar import (desktop one-click sync)
# Create an OAuth client ID for a desktop app in Google Cloud and paste it here.
JARVIS_GOOGLE_CLIENT_ID=
