{
  "name": "@jarvis/desktop",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main.cjs",
  "types": "dist-types/main/main.d.ts",
  "dependencies": {
    "@jarvis/core": "0.1.0",
    "electron": "^40.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs && tsc -p tsconfig.json",
    "dev": "npm run build && electron ./dist/main.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "test": "vitest run --config ../../vitest.config.ts"
  }
}
